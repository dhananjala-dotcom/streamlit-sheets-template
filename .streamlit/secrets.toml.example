# This file documents the shape of secrets used by step 3.
# DO NOT put real secrets here — this file is committed to git.
#
# For local development: copy this to .streamlit/secrets.toml (which is
#   gitignored) and fill in real values.
# For Streamlit Community Cloud: paste these as TOML into your app's
#   "Secrets" panel (App settings → Secrets). They are NOT read from this file.

# The ID of your Google Sheet, copied from its URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
sheet_id = "REPLACE_WITH_YOUR_SHEET_ID"

# Single shared password for the admin app. Anyone with this can view & edit.
admin_password = "REPLACE_WITH_A_STRONG_PASSWORD"

# Service-account credentials from the JSON key you downloaded from Google
# Cloud Console (Service Accounts → Keys → Add key → JSON). Paste each
# field as-is into the corresponding line below.
#
# Tip: the private_key value contains "\n" sequences — keep them as-is
# inside the double quotes. TOML interprets them as newlines automatically.
[gcp_service_account]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "your-service-account@your-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
